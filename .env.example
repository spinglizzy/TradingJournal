# Copy this file to .env and fill in your values

# Supabase project URL (from Supabase Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for frontend use — subject to RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — BACKEND ONLY, never expose to client or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase connection string (from Supabase project Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Set to 'false' only for a local PostgreSQL instance without SSL
DATABASE_SSL=true

# Server port (optional, defaults to 3001)
PORT=3001

# Comma-separated list of allowed CORS origins.
# In dev this defaults to http://localhost:5173.
# In production set this to your Vercel URL (e.g. https://pulsejournal.vercel.app)
# and add it to Vercel's Environment Variables in the project settings.
ALLOWED_ORIGIN=https://your-app.vercel.app
